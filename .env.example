# ============================================================
# AgentsOffice 环境变量配置
# 复制此文件为 .env 并填入你的真实值
# .env 已加入 .gitignore，不会被提交到 git
# ============================================================

# ---------- 数据库 ----------
DATABASE_URL_SYNC=postgresql://agents_dev:agents_dev_pass@localhost:5432/agents_office

# ---------- LLM API Keys（填你有的，没有的留空） ----------
# Google Gemini
GEMINI_API_KEY=

# Anthropic Claude（可选）
ANTHROPIC_API_KEY=

# OpenAI ChatGPT（可选）
OPENAI_API_KEY=

# DeepSeek（可选）
DEEPSEEK_API_KEY=

# DashScope / 通义千问（可选）
DASHSCOPE_API_KEY=

# ---------- 默认模型配置 ----------
# 留空则需在 Agent 配置面板中为每个 Agent 单独设置
# 支持的格式: gpt-4o / gemini/gemini-2.5-flash / qwen-plus / deepseek-chat
DEFAULT_LLM_MODEL=
