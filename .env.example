# ---------- 数据库 ----------
DATABASE_URL_SYNC=postgresql://ecom_dev:ecom_dev_pass@localhost:5432/ecom_ai_lab

# ---------- LLM API Keys（至少填一个） ----------
# Google Gemini
GEMINI_API_KEY=

# 阿里云百炼 DashScope（可选）
DASHSCOPE_API_KEY=

# OpenAI ChatGPT（可选）
OPENAI_API_KEY=

# DeepSeek（可选）
DEEPSEEK_API_KEY=

# Anthropic Claude（可选）
ANTHROPIC_API_KEY=
